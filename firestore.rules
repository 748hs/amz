rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tests/{testId} {
      allow read, write: if true;
    }
    match /participants/{participantId} {
      allow read, write: if true;
    }
    match /submissions/{submissionId} {
      allow read, write: if true;
    }
    match /activeSessions/{sessionId} {
      allow read, write: if true;
    }
  }
}
